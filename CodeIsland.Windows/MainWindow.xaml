<Window x:Class="CodeIsland.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodeIsland.Windows"
        xmlns:core="clr-namespace:CodeIsland.Core;assembly=CodeIsland.Core"
        Title="CodeIsland" Width="780" SizeToContent="Height" MaxHeight="720"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual" FontFamily="Cascadia Mono, Consolas"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <local:SessionTitleConverter x:Key="SessionTitleConverter"/>
        <local:SessionElapsedConverter x:Key="SessionElapsedConverter"/>
        <local:SessionStateBrushConverter x:Key="SessionStateBrushConverter"/>
        <local:SessionStatusTextConverter x:Key="SessionStatusTextConverter"/>
        <local:AgentAccentConverter x:Key="AgentAccentConverter"/>
        <local:AgentGroupHeaderConverter x:Key="AgentGroupHeaderConverter"/>
        <local:AgentGifPathConverter x:Key="AgentGifPathConverter"/>
        <local:AgentGifSizeConverter x:Key="AgentGifSizeConverter"/>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="40"/><Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="#FFB7B7BC"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="bg" Width="40" Height="40" CornerRadius="5" Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#FF171719"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="Background" Value="#FF19191B"/><Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="9,5"/><Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE8E8EA"/><Setter Property="Background" Value="#FF18181A"/>
            <Setter Property="BorderBrush" Value="#FF3B3B3F"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="72"/><Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/><Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="ActionChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ActionChrome" Property="Opacity" Value="0.86"/></Trigger>
                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="ActionChrome" Property="Opacity" Value="0.72"/></Trigger>
                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ActionChrome" Property="Opacity" Value="0.38"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="ApproveActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="#FF07130B"/><Setter Property="Background" Value="#FF42E879"/><Setter Property="BorderBrush" Value="#FF66F293"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="#FF07130B"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="DenyActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="#FFFF747B"/><Setter Property="BorderBrush" Value="#FF713137"/>
        </Style>
        <Style x:Key="AlwaysActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="#FFFFC45A"/><Setter Property="BorderBrush" Value="#FF6C5227"/><Setter Property="MinWidth" Value="96"/>
        </Style>
        <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton">
                <Border Background="{TemplateBinding Background}"/>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="30"/><Setter Property="Margin" Value="1,2"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb">
                <Border x:Name="ThumbChrome" Background="#FF4A4A4F" CornerRadius="3"/>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbChrome" Property="Background" Value="#FF68686E"/></Trigger>
                    <Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbChrome" Property="Background" Value="#FF85858B"/></Trigger>
                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ThumbChrome" Property="Opacity" Value="0.35"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="DarkVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/><Setter Property="Margin" Value="5,2,0,2"/>
            <Setter Property="Background" Value="#FF09090A"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar">
                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                    <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                        <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageUpCommand"/></Track.DecreaseRepeatButton>
                        <Track.Thumb><Thumb Style="{StaticResource DarkScrollThumb}"/></Track.Thumb>
                        <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageDownCommand"/></Track.IncreaseRepeatButton>
                    </Track>
                </Border>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="PanelChrome" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform><ScaleTransform x:Name="PanelScale" ScaleX="1" ScaleY="1"/></Grid.RenderTransform>
    <Border x:Name="PanelBorder" CornerRadius="24" Background="#FF000000" BorderBrush="#FF252528"
            BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid x:Name="ExpandedPanel" Margin="16,12,16,16">
                <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="1"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid Margin="2,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions>
                    <Border Width="38" Height="20" CornerRadius="10" Background="#FF28282B" VerticalAlignment="Center" Margin="0,0,18,0">
                        <Grid><Ellipse Width="7" Height="7" Fill="#FFFFB43C" HorizontalAlignment="Left" Margin="9,0,0,0"/>
                            <Rectangle Width="7" Height="10" RadiusX="1" Fill="#FFF3F3F3" HorizontalAlignment="Right" Margin="0,0,9,0"/></Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="AllFilter" Background="#FF242426" BorderBrush="#FF3A3A3D" BorderThickness="1" Padding="13,8" CornerRadius="5,0,0,5" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="all"><TextBlock Text="ALL" Foreground="#FF8A8A8F" FontWeight="Bold" FontSize="14"/></Border>
                        <Border x:Name="ActiveFilter" Background="#FF161618" BorderBrush="#FF2B2B2E" BorderThickness="0,1,1,1" Padding="13,8" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="active"><TextBlock Text="STA" Foreground="#FF8A8A8F" FontWeight="Bold" FontSize="14"/></Border>
                        <Border x:Name="CliFilter" Background="#FF161618" BorderBrush="#FF2B2B2E" BorderThickness="0,1,1,1" Padding="13,8" CornerRadius="0,5,5,0" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="cli"><TextBlock Text="CLI" Foreground="#FF37D067" FontWeight="Bold" FontSize="14"/></Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="SoundButton" Style="{StaticResource IconButton}" Content="&#xE767;" ToolTip="Sound" Click="OnSoundClick"/>
                        <Button Style="{StaticResource IconButton}" Content="&#xE713;" ToolTip="Settings" Click="OnSettingsClick"/>
                        <Button Style="{StaticResource IconButton}" Content="&#xE7E8;" Foreground="#FFDA525A" ToolTip="Exit" Click="OnExitClick"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Background="#FF242427"/>
                <Grid Grid.Row="2">
                    <StackPanel HorizontalAlignment="Center" Margin="0,28,0,20">
                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsIdle}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                        <TextBlock Text="CODEISLAND 0" Foreground="#FFE0E0E2" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource IdleText}" Foreground="#FF76767C" FontSize="13" HorizontalAlignment="Center" Margin="0,7,0,0"/>
                    </StackPanel>
                    <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                        <ScrollViewer.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource DarkVerticalScrollBar}"/></ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding Sessions}">
                            <ItemsControl.GroupStyle><GroupStyle><GroupStyle.HeaderTemplate><DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,12,0,8">
                                    <TextBlock Text="+" Foreground="{Binding Path=., Mode=OneWay, Converter={StaticResource AgentAccentConverter}}" FontSize="18" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Path=., Mode=OneWay, Converter={StaticResource AgentGroupHeaderConverter}}" Foreground="#FF97979D" FontWeight="Bold" FontSize="15"/>
                                </StackPanel>
                            </DataTemplate></GroupStyle.HeaderTemplate></GroupStyle></ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type core:SessionSnapshot}">
                                <Border Background="#FF0D0D0E" CornerRadius="14" Margin="0,0,0,9" Padding="10,12"
                                        AllowDrop="True" Tag="{Binding Path=., Mode=OneWay}" Cursor="SizeNS"
                                        MouseLeftButtonDown="OnSessionDragStart" MouseMove="OnSessionDragMove"
                                        DragOver="OnSessionDragOver" Drop="OnSessionDrop">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <local:AnimatedGifImage Grid.Column="0" Width="{Binding Agent, Mode=OneWay, Converter={StaticResource AgentGifSizeConverter}}" Height="{Binding Agent, Mode=OneWay, Converter={StaticResource AgentGifSizeConverter}}" Margin="4,0,12,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            RenderOptions.BitmapScalingMode="NearestNeighbor" SourcePath="{Binding Agent, Mode=OneWay, Converter={StaticResource AgentGifPathConverter}, ConverterParameter=expanded}"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,14,0">
                                            <TextBlock FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Path=., Mode=OneWay, Converter={StaticResource SessionTitleConverter}}" Foreground="{Binding State, Mode=OneWay, Converter={StaticResource SessionStateBrushConverter}}"/>
                                                <Run Text="  #" Foreground="#FF5F5F65"/><Run Text="{Binding SessionId, Mode=OneWay}" Foreground="#FF5F5F65" FontSize="12"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,9,0,0" TextTrimming="CharacterEllipsis" Foreground="#FFE0E0E3" FontSize="14"><Run Text="> " Foreground="#FF37D067" FontWeight="Bold"/><Run Text="{Binding LastMessage, Mode=OneWay, TargetNullValue=working...}"/></TextBlock>
                                            <TextBlock Margin="0,6,0,0" TextTrimming="CharacterEllipsis" Foreground="#FF99999F" FontSize="14"><Run Text="$ " Foreground="#FFF27E4A" FontWeight="Bold"/><Run Text="{Binding Path=., Mode=OneWay, Converter={StaticResource SessionStatusTextConverter}}"/></TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding State}" Value="WaitingForPermission"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                <Button Style="{StaticResource ApproveActionButton}" Content="{DynamicResource ApproveText}" Tag="{Binding PendingEventId}" Click="OnApproveClick"/><Button Style="{StaticResource DenyActionButton}" Content="{DynamicResource DenyText}" Tag="{Binding PendingEventId}" Click="OnDenyClick"/><Button Style="{StaticResource AlwaysActionButton}" Content="{DynamicResource AlwaysAllowText}" Tag="{Binding PendingEventId}" Click="OnAlwaysAllowClick"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding State}" Value="WaitingForAnswer"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                <TextBox Width="250" Height="30" Tag="{Binding PendingEventId}" TextChanged="OnAnswerChanged" Padding="8,4" Background="#FF111113" Foreground="#FFE8E8EA" BorderBrush="#FF343438" CaretBrush="#FF42E879"/><Button Style="{StaticResource ApproveActionButton}" Content="{DynamicResource SendText}" Tag="{Binding PendingEventId}" Click="OnAnswerClick" Margin="7,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Border Style="{StaticResource Pill}"><TextBlock Text="{Binding StartedAt, Mode=OneWay, Converter={StaticResource SessionElapsedConverter}}" Foreground="#FFB5B5BA" FontWeight="Bold"/></Border>
                                            <Border Style="{StaticResource Pill}" Background="#FF0B2012" Cursor="Hand" MouseLeftButtonUp="OnJumpPillClick" Tag="{Binding Path=., Mode=OneWay}"><StackPanel Orientation="Horizontal"><TextBlock Text="&gt;_" Foreground="#FF37D067" Margin="0,0,7,0"/><TextBlock Text="{Binding TerminalKind, Mode=OneWay, TargetNullValue=Terminal}" Foreground="#FF37D067" FontWeight="Bold"/><TextBlock Text="  &gt;" Foreground="#FF258A48"/></StackPanel></Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Grid x:Name="CollapsedPanel" Visibility="Collapsed" Margin="8,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <local:AnimatedGifImage Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="NearestNeighbor" SourcePath="{Binding CurrentSession.Agent, Mode=OneWay, Converter={StaticResource AgentGifPathConverter}}"/>
                <Border Grid.Column="1" Margin="4,0,8,0" BorderBrush="#FF123D21" BorderThickness="0,0,0,1" VerticalAlignment="Center" Padding="0,0,0,2">
                    <TextBlock Text="{Binding CurrentSession, Mode=OneWay, Converter={StaticResource SessionStatusTextConverter}}"
                        Foreground="#FF39E46E" FontFamily="Cascadia Mono, Consolas" FontWeight="Bold" FontSize="14"
                        TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxHeight="20"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
        <Path x:Name="DockShoulderFirst" Fill="#FF000000" IsHitTestVisible="False"/>
        <Path x:Name="DockShoulderSecond" Fill="#FF000000" IsHitTestVisible="False"/>
    </Grid>
</Window>
