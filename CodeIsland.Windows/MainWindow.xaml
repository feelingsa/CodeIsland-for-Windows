<Window x:Class="CodeIsland.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodeIsland.Windows"
        xmlns:core="clr-namespace:CodeIsland.Core;assembly=CodeIsland.Core"
        Title="CodeIsland" Height="650" Width="780"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual" FontFamily="Cascadia Mono, Consolas">
    <Window.Resources>
        <local:SessionTitleConverter x:Key="SessionTitleConverter"/>
        <local:SessionElapsedConverter x:Key="SessionElapsedConverter"/>
        <local:SessionStateBrushConverter x:Key="SessionStateBrushConverter"/>
        <local:SessionStatusTextConverter x:Key="SessionStatusTextConverter"/>
        <local:AgentAccentConverter x:Key="AgentAccentConverter"/>
        <local:AgentGifPathConverter x:Key="AgentGifPathConverter"/>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34"/><Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="#FFB7B7BC"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="bg" CornerRadius="5" Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#FF171719"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="Background" Value="#FF19191B"/><Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="9,5"/><Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFD8D8DC"/><Setter Property="Background" Value="#FF202023"/>
            <Setter Property="BorderBrush" Value="#FF303034"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/><Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <CollectionViewSource x:Key="GroupedSessions" Source="{Binding Sessions}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Agent"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Border x:Name="PanelBorder" CornerRadius="24" Background="#FF000000" BorderBrush="#FF1D1D20"
            BorderThickness="1" Padding="16,12,16,16" RenderTransformOrigin="0.5,0" ClipToBounds="True">
        <Border.RenderTransform><ScaleTransform x:Name="PanelScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="1"/><RowDefinition Height="*"/></Grid.RowDefinitions>

            <Grid Margin="2,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="34" Height="18" CornerRadius="9" Background="#FF28282B" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Grid><Ellipse Width="6" Height="6" Fill="#FFFFB43C" HorizontalAlignment="Left" Margin="8,0,0,0"/>
                        <Rectangle Width="6" Height="9" RadiusX="1" Fill="#FFF3F3F3" HorizontalAlignment="Right" Margin="0,0,8,0"/></Grid>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="AllFilter" Background="#FF242426" BorderBrush="#FF3A3A3D" BorderThickness="1" Padding="12,7" CornerRadius="4,0,0,4" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="all">
                        <TextBlock Text="ALL" Foreground="#FF747478" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border x:Name="ActiveFilter" Background="#FF161618" BorderBrush="#FF2B2B2E" BorderThickness="0,1,1,1" Padding="12,7" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="active">
                        <TextBlock Text="STA" Foreground="#FF747478" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border x:Name="CliFilter" Background="#FF161618" BorderBrush="#FF2B2B2E" BorderThickness="0,1,1,1" Padding="12,7" CornerRadius="0,4,4,0" Cursor="Hand" MouseLeftButtonUp="OnFilterClick" Tag="cli">
                        <TextBlock Text="CLI" Foreground="#FF37D067" FontWeight="Bold" FontSize="13"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Content="◖" ToolTip="Sound"/>
                    <Button Style="{StaticResource IconButton}" Content="⚙" ToolTip="Settings" Click="OnSettingsClick"/>
                    <Button Style="{StaticResource IconButton}" Content="⏻" Foreground="#FFDA525A" ToolTip="Exit" Click="OnExitClick"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Background="#FF242427" Margin="0,0"/>

            <Grid Grid.Row="2">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers><DataTrigger Binding="{Binding IsIdle}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                    </Style></StackPanel.Style>
                    <TextBlock Text="▟████▙" Foreground="#FF85858B" FontSize="22" HorizontalAlignment="Center"/>
                    <TextBlock Text="CodeIsland 0" Foreground="#FFE0E0E2" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="等待 AI 编程会话" Foreground="#FF76767C" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedSessions}}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate><DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,11,0,8">
                                        <TextBlock Text="✦" Foreground="{Binding Name, Converter={StaticResource AgentAccentConverter}}" FontSize="18" Margin="0,0,8,0"/>
                                        <TextBlock Foreground="#FF97979D" FontWeight="Bold" FontSize="15">
                                            <Run Text="{Binding Name}"/><Run Text=" ("/><Run Text="{Binding ItemCount}"/><Run Text=")"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate></GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type core:SessionSnapshot}">
                                <Border Background="#FF0D0D0E" CornerRadius="14" Margin="0,0,0,9" Padding="18,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="72"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" VerticalAlignment="Center">
                                            <local:AnimatedGifImage Width="56" Height="56" SourcePath="{Binding Agent, Converter={StaticResource AgentGifPathConverter}}"/>
                                        </Grid>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,16,0">
                                            <TextBlock FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Converter={StaticResource SessionTitleConverter}}" Foreground="{Binding State, Converter={StaticResource SessionStateBrushConverter}}"/>
                                                <Run Text="  #" Foreground="#FF5F5F65"/><Run Text="{Binding SessionId, Mode=OneWay}" Foreground="#FF5F5F65" FontSize="12"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,8,0,0" TextTrimming="CharacterEllipsis" Foreground="#FFE0E0E3" FontSize="14">
                                                <Run Text="> " Foreground="#FF37D067" FontWeight="Bold"/><Run Text="{Binding LastMessage, TargetNullValue=working...}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,5,0,0" TextTrimming="CharacterEllipsis" Foreground="#FF99999F" FontSize="14">
                                                <Run Text="$ " Foreground="#FFF27E4A" FontWeight="Bold"/><Run Text="{Binding Converter={StaticResource SessionStatusTextConverter}}"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding State}" Value="WaitingForPermission"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                                </Style></StackPanel.Style>
                                                <Button Style="{StaticResource ActionButton}" Content="{DynamicResource ApproveText}" Tag="{Binding PendingEventId}" Click="OnApproveClick"/>
                                                <Button Style="{StaticResource ActionButton}" Content="{DynamicResource DenyText}" Tag="{Binding PendingEventId}" Click="OnDenyClick"/>
                                                <Button Style="{StaticResource ActionButton}" Content="{DynamicResource AlwaysAllowText}" Tag="{Binding PendingEventId}" Click="OnAlwaysAllowClick"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding State}" Value="WaitingForAnswer"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                                </Style></StackPanel.Style>
                                                <TextBox Width="250" Tag="{Binding PendingEventId}" TextChanged="OnAnswerChanged" Padding="7,5" Background="#FF171719" Foreground="White" BorderBrush="#FF343438"/>
                                                <Button Style="{StaticResource ActionButton}" Content="{DynamicResource SendText}" Tag="{Binding PendingEventId}" Click="OnAnswerClick" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Border Style="{StaticResource Pill}"><TextBlock Text="{Binding StartedAt, Converter={StaticResource SessionElapsedConverter}}" Foreground="#FFB5B5BA" FontWeight="Bold"/></Border>
                                            <Border Style="{StaticResource Pill}" Background="#FF0B2012" Cursor="Hand" MouseLeftButtonUp="OnJumpPillClick" Tag="{Binding}">
                                                <StackPanel Orientation="Horizontal"><TextBlock Text="▣" Foreground="#FF37D067" Margin="0,0,7,0"/>
                                                    <TextBlock Text="{Binding TerminalKind, TargetNullValue=Terminal}" Foreground="#FF37D067" FontWeight="Bold"/>
                                                    <TextBlock Text="  →" Foreground="#FF258A48"/></StackPanel>
                                            </Border>
                                            <Button Style="{StaticResource IconButton}" Content="×" FontSize="16" Width="25" Height="25" Margin="5,0,0,0" Tag="{Binding SessionId}" Click="OnCloseSessionClick" ToolTip="{DynamicResource CloseSessionText}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
