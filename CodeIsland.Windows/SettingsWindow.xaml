<Window x:Class="CodeIsland.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodeIsland Settings" Width="720" Height="520" WindowStartupLocation="CenterScreen"
        Background="#FF000000" Foreground="White" MinWidth="620" MinHeight="440">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="White"/></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="#FF141414"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#FF3B424E"/></Style>
        <Style TargetType="ComboBox"><Setter Property="Background" Value="#FF141414"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#FF3B424E"/></Style>
        <Style TargetType="TabControl"><Setter Property="Background" Value="#FF000000"/><Setter Property="BorderBrush" Value="#FF343A46"/></Style>
        <Style TargetType="TabItem"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#FF151515"/></Style>
        <Style TargetType="DataGrid"><Setter Property="Background" Value="#FF090909"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#FF343A46"/><Setter Property="RowBackground" Value="#FF090909"/><Setter Property="AlternatingRowBackground" Value="#FF141414"/></Style>
    </Window.Resources>
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Import" Click="OnImport" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="Export" Click="OnExport" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="Defaults" Click="OnDefaults" Padding="12,7" Margin="0,0,18,0"/>
            <Button Content="Cancel" Click="OnCancel" Padding="18,7" Margin="0,0,8,0"/>
            <Button Content="Save" Click="OnSave" Padding="18,7" IsDefault="True"/>
        </StackPanel>
        <TabControl>
            <TabItem Header="General">
                <StackPanel Margin="18">
                    <TextBlock Text="Language" FontWeight="SemiBold"/>
                    <ComboBox x:Name="LanguageBox" Width="220" HorizontalAlignment="Left" Margin="0,7,0,18">
                        <ComboBoxItem Content="System" Tag="system"/><ComboBoxItem Content="简体中文" Tag="zh-CN"/><ComboBoxItem Content="English" Tag="en-US"/>
                    </ComboBox>
                    <CheckBox x:Name="LaunchAtLoginBox" Content="Launch CodeIsland when I sign in" Margin="0,0,0,18"/>
                    <TextBlock x:Name="GeneralStatus" Text="Settings are stored in your roaming AppData folder." Foreground="#FFABB3C0"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Behavior">
                <StackPanel Margin="18">
                    <TextBlock Text="Session cleanup (minutes)" FontWeight="SemiBold"/>
                    <TextBox x:Name="CleanupMinutesBox" Width="120" HorizontalAlignment="Left" Margin="0,7,0,18"/>
                    <TextBlock Text="Inactive sessions are removed automatically after this period." Foreground="#FFABB3C0"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Appearance">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Maximum visible sessions" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxSessionsBox" Grid.Column="1" Margin="8"/>
                    <TextBlock Grid.Row="1" Text="Event history limit" VerticalAlignment="Center"/>
                    <TextBox x:Name="HistoryLimitBox" Grid.Row="1" Grid.Column="1" Margin="8"/>
                </Grid>
            </TabItem>
            <TabItem Header="Sound">
                <StackPanel Margin="18">
                    <CheckBox x:Name="SoundEnabledBox" Content="Play sounds for session events"/>
                    <TextBlock Text="Sounds are played for start, approval, completion and error events." Foreground="#FFABB3C0" Margin="0,12,0,0"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Hooks">
                <Grid Margin="18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Button Content="Refresh" Click="OnRefreshHooks" Width="90" HorizontalAlignment="Left" Padding="10,5"/>
                    <DataGrid x:Name="HooksGrid" Grid.Row="1" Margin="0,12,0,0" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tool" Binding="{Binding Tool.DisplayName}" Width="140"/>
                            <DataGridCheckBoxColumn Header="Executable" Binding="{Binding HasExecutable}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Hook" Binding="{Binding HookInstalled}" Width="70"/>
                            <DataGridCheckBoxColumn Header="Healthy" Binding="{Binding IsHealthy}" Width="70"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Problem}" Width="*"/>
                            <DataGridTemplateColumn Header="Actions" Width="220">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Install" Tag="{Binding Tool}" Click="OnInstallHook" Padding="7,3" Margin="0,0,4,0"/>
                                        <Button Content="Repair" Tag="{Binding Tool}" Click="OnRepairHook" Padding="7,3" Margin="0,0,4,0"/>
                                        <Button Content="Uninstall" Tag="{Binding Tool}" Click="OnUninstallHook" Padding="7,3"/>
                                    </StackPanel>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="HookOperationStatus" Grid.Row="2" Foreground="#FFABB3C0" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="Shortcuts">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Toggle panel" VerticalAlignment="Center"/><TextBox x:Name="ToggleShortcutBox" Grid.Column="1" Margin="8,4"/>
                    <TextBlock Grid.Row="1" Text="Approve request" VerticalAlignment="Center"/><TextBox x:Name="ApproveShortcutBox" Grid.Row="1" Grid.Column="1" Margin="8,4"/>
                    <TextBlock Grid.Row="2" Text="Deny request" VerticalAlignment="Center"/><TextBox x:Name="DenyShortcutBox" Grid.Row="2" Grid.Column="1" Margin="8,4"/>
                    <TextBlock x:Name="ShortcutStatus" Grid.Row="3" Grid.ColumnSpan="2" Foreground="#FFABB3C0" Margin="0,12,0,0" Text="Format: Ctrl+Shift+I, Alt+Shift+A, or Win+Ctrl+D"/>
                </Grid>
            </TabItem>
            <TabItem Header="About">
                <StackPanel Margin="18">
                    <TextBlock Text="CodeIsland for Windows" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Version 0.1.0" Margin="0,8,0,0"/>
                    <TextBlock Text="Real-time AI coding agent status panel." Foreground="#FFABB3C0" Margin="0,14,0,0"/>
                    <TextBlock Text="MIT License" Margin="0,18,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
